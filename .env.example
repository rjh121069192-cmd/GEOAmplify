APP_NAME=GEOAmplify
APP_ENV=local
# 复制为 .env 后运行 `php artisan key:generate` 写入。
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
# 反向代理/CDN/一级目录部署时按需设置，例如 *、REMOTE_ADDR 或具体代理 IP。
TRUSTED_PROXIES=
# Laravel Boost 仅用于本地调试；公开环境应关闭浏览器日志脚本注入。
BOOST_BROWSER_LOGS_WATCHER=false
APP_TIMEZONE=Asia/Shanghai

# --- GEOAmplify（见 config/geoamplify.php）---
SITE_NAME="智能GEO内容系统"
SITE_FULL_NAME="GEO+AI内容生成系统"
SITE_URL="${APP_URL}"
SITE_DESCRIPTION=
SITE_KEYWORDS=
ADMIN_BASE_PATH=geo_admin
# 前台 Blade 翻译语言（与 APP_LOCALE 独立；默认 zh_CN 对齐旧站中文导航）
GEOAMPLIFY_PUBLIC_LOCALE=zh_CN

GEOAMPLIFY_ITEMS_PER_PAGE=12
GEOAMPLIFY_ADMIN_ITEMS_PER_PAGE=20
# 标题库 AI 生成时从关键词库随机抽取条数上限（1–100）
GEOAMPLIFY_TITLE_AI_KEYWORD_SAMPLE_LIMIT=10
# true 时记录知识库检索「查询向量」是否由 embedding 接口生成（验证用，默认 false）
GEOAMPLIFY_DEBUG_KNOWLEDGE_QUERY_EMBEDDING=false
# 语义切片规划 prompt 的最大字符预算；超过后自动回退规则切片。
GEOAMPLIFY_SEMANTIC_CHUNKING_MAX_CHARS=20000
# Embedding 批量请求大小；Gemini 原生接口默认 1，更稳妥。
GEOAMPLIFY_EMBEDDING_BATCH_SIZE=1
# GEO 生产链路批量采集、批量评分、发布后复测是否走 Laravel 队列；本地调试建议 false，生产建议 true 并启动 queue worker。
GEOAMPLIFY_GEO_ASYNC_JOBS=false
# 本机多平台 AI 网页对话工作台 CLI；外部问答检视选择真实网页平台时使用。
GEOAMPLIFY_AI_WEB_WORKBENCH_COMMAND=
GEOAMPLIFY_AI_WEB_WORKBENCH_TIMEOUT=420
GEOAMPLIFY_AI_WEB_WORKBENCH_LOGIN_CHECK_TIMEOUT=90
GEOAMPLIFY_AI_WEB_WORKBENCH_DATA_DIR=
# 蚁小二发布链路：公众号草稿提交前会先查账号状态，再上传素材和创建任务集。
YIXIAOER_API_KEY=
YIXIAOER_API_URL=https://www.yixiaoer.cn/api
# 任务页是否连接 Reverb 实时推送；开启前需同时启动 Reverb 服务，否则保持 false。
GEOAMPLIFY_TASK_REALTIME_ENABLED=false
# URL 智能采集 SSRF 防护默认严格；仅在明确受控的透明代理或 VPN 混合 DNS 环境中开启。
URL_IMPORT_ALLOW_MIXED_DNS=false
GEOAMPLIFY_UPLOAD_URL=/assets/images/
GEOAMPLIFY_MAX_UPLOAD_BYTES=2097152
GEOAMPLIFY_CACHE_ENABLED=true
GEOAMPLIFY_CACHE_TTL=3600
GEOAMPLIFY_MAX_LOGIN_ATTEMPTS=5
GEOAMPLIFY_LOGIN_LOCKOUT_SECONDS=900
GEOAMPLIFY_SESSION_TIMEOUT=2592000
GEOAMPLIFY_API_LOGIN_RATE_LIMIT_ATTEMPTS=10
GEOAMPLIFY_API_LOGIN_RATE_LIMIT_DECAY=60
GEOAMPLIFY_API_TOKEN_DEFAULT_TTL_DAYS=30
# 首次 seed 写入的默认后台账号；重复执行不会覆盖已有账号。正式使用前必须修改默认密码。
GEOAMPLIFY_ADMIN_USERNAME=admin
GEOAMPLIFY_ADMIN_EMAIL=admin@example.com
GEOAMPLIFY_ADMIN_PASSWORD=password
# 变更后所有管理员会再次看到「欢迎使用 GEOAmplify」介绍弹窗
GEOAMPLIFY_APP_VERSION=1.2.0
GEOAMPLIFY_WELCOME_INTRO_VERSION=1.2.0
# 后台右上角通知会每天最多拉取一次 GitHub version.json；如需关闭，设置为 false
GEOAMPLIFY_UPDATE_CHECK_ENABLED=true
GEOAMPLIFY_UPDATE_METADATA_URL=https://raw.githubusercontent.com/rjh121069192-cmd/GEOAmplify/main/version.json
GEOAMPLIFY_UPDATE_METADATA_CACHE_TTL=86400

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=geo_amplify
DB_USERNAME=geo_user
DB_PASSWORD=geo_password

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=geoamplify-reverb-app
REVERB_APP_KEY=geoamplify-reverb-key
REVERB_APP_SECRET=geoamplify-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_BROADCAST_HOST=127.0.0.1
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
FILESYSTEM_DISK=local
# 生产与计划一致用 redis；本机未装 Redis 时可改为 sync 或 database
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# 须大于应用内最长队列任务 timeout（如 ProcessGeoAmplifyTaskJob 为 300 秒）
REDIS_QUEUE_RETRY_AFTER=360

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
